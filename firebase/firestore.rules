// ============================================================
//  CLUBLINK APP — Regras de Segurança do Cloud Firestore
// ============================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────
    function isAuth()     { return request.auth != null; }
    function me()         { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isDirector() { return isAuth() && me().role == 'diretoria'; }
    function isAdmin()    { return isDirector() && me().isAdmin == true; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }

    // hasPerm: admin bypassa qualquer verificação de permissão individual
    function hasPerm(perm) {
      return isAuth()
        && me().role == 'diretoria'
        && (me().isAdmin == true
            || (me().get('permissions', []) is list
                && perm in me().get('permissions', [])));
    }

    function onlyAllowedFields(allowed) {
      return request.resource.data.diff(resource.data)
             .affectedKeys().hasOnly(allowed);
    }

    // ── app_config ───────────────────────────────────────────
    // Leitura pública — necessário para exibir tela de status antes do login
    match /app_config/{docId} {
      allow read: if true;
      allow create, update: if isAdmin()
        && request.resource.data.keys().hasAll(['status', 'since', 'updatedBy'])
        && request.resource.data.status in ['production', 'maintenance', 'offline'];
      allow delete: if false;
    }

    // ── users ─────────────────────────────────────────────────
    match /users/{uid} {

      // Qualquer autenticado pode ler (necessário para ranking e listeners)
      allow read: if isAuth();

      // Criação: diretoria com register.edit OU admin.
      // Nota: o setDoc é executado com o Firestore autenticado como o
      // admin/diretor logado — não como o novo usuário sendo criado.
      allow create: if hasPerm('register.edit');

      // Atualização:
      //   • Próprio usuário → apenas campos pessoais seguros (sem role, points, isAdmin…)
      //   • Diretoria com members.edit (inclui admin via hasPerm)
      allow update: if
        (isOwner(uid) && onlyAllowedFields([
          'name', 'unit', 'position', 'birth',
          'photoUrl', 'googleUid',
          'lastUpdate', 'lastUpdatedBy'
        ]))
        || hasPerm('members.edit');

      // Exclusão: diretoria com members.delete (inclui admin via hasPerm)
      allow delete: if hasPerm('members.delete');

      // ── history (sub-collection) ─────────────────────────
      match /history/{entryId} {
        allow read: if isOwner(uid) || hasPerm('appointments.view');

        allow create: if hasPerm('appointments.edit')
          && request.resource.data.keys().hasAll(['type','finalPoints','updatedBy','timestamp'])
          && request.resource.data.type in ['add','reset']
          && request.resource.data.finalPoints >= 0;

        allow update: if false;  // histórico imutável
        allow delete: if hasPerm('members.delete');
      }
    }

    // ── events ────────────────────────────────────────────────
    match /events/{eventId} {
      // Leitura: autenticados; eventos privados apenas para diretoria
      allow read: if isAuth()
        && (resource.data.isPrivate == false || isDirector());

      // Criar: agenda.edit (inclui admin via hasPerm)
      allow create: if hasPerm('agenda.edit')
        && request.resource.data.keys().hasAll(['title','start','source','isPrivate'])
        && request.resource.data.source in ['manual','import','birthday'];

      // Editar e excluir: agenda.edit — qualquer evento (manual, import, birthday)
      allow update: if hasPerm('agenda.edit');
      allow delete: if hasPerm('agenda.edit');
    }

    // ── scorings ──────────────────────────────────────────────
    // Pontuações padrão (itens de scoring)
    match /scorings/{scoringId} {
      // Qualquer autenticado lê (necessário para modal de tabela em todas as telas)
      allow read: if isAuth();

      // Criar, editar e excluir: scoring.edit (inclui admin via hasPerm)
      allow create, update, delete: if hasPerm('scoring.edit');
    }

    // ── notices ───────────────────────────────────────────────
    // Quadro de Avisos: leitura para autenticados,
    // escrita restrita a quem tem notices.edit
    match /notices/{noticeId} {
      allow read: if isAuth();

      // Criação/edição/exclusão do aviso em si — apenas notices.edit
      allow create, delete: if hasPerm('notices.edit');

      // Update: notices.edit (edição do conteúdo) OU qualquer autenticado
      // alterando SOMENTE replyCount (via transação ao criar/excluir resposta)
      allow update: if hasPerm('notices.edit')
        || (isAuth() && request.resource.data.diff(resource.data)
              .affectedKeys().hasOnly(['replyCount']));

      // ── replies (sub-collection) ───────────────────────────
      // Tópico de discussão linear — sem respostas de respostas
      match /replies/{replyId} {
        // Qualquer autenticado lê e cria respostas
        allow read:   if isAuth();
        allow create: if isAuth()
          && request.resource.data.keys().hasAll(['authorUid','authorName','text','createdAt'])
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500
          && request.resource.data.likedBy == []
          && request.resource.data.pinned == false;

        // Update: like/unlike (qualquer autenticado, só campo likedBy)
        // OU pin/unpin (apenas o autor do AVISO pai, só campo pinned)
        allow update: if isAuth()
          && (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy'])
            || (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pinned'])
              && get(/databases/$(database)/documents/notices/$(noticeId)).data.authorUid == request.auth.uid
            )
          );

        // Excluir: autor da resposta, autor do aviso, ou notices.edit
        allow delete: if isAuth()
          && (
            resource.data.authorUid == request.auth.uid
            || get(/databases/$(database)/documents/notices/$(noticeId)).data.authorUid == request.auth.uid
            || hasPerm('notices.edit')
          );
      }
    }

    // ── import_log ────────────────────────────────────────────
    match /import_log/{logId} {
      allow read:          if hasPerm('agenda.edit');
      allow create:        if hasPerm('agenda.edit');
      allow update, delete: if false;  // logs imutáveis
    }

    // ── catch-all — nega tudo não mapeado acima ───────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
